@page "/company/business-categories"
@inject TokenStore TokenStore
@inject OAuthService OAuthService
@inject ApiDiagnosticsService ApiDiagnostics
@inject NavigationManager NavigationManager

<PageTitle>Business Categories — FreeAgent SDK Sample</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="sample-page">
    <EndpointProbeHeader SectionKicker="Company endpoint"
                         Title="Business categories"
                         CallUnderTest="CompanyService.GetBusinessCategoriesAsync()"
                         Description="Renders all categories returned by FreeAgent."
                         EndpointPath="/v2/company/business_categories" />

    @if (!TokenStore.IsConnected)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
            This probe needs an OAuth session first.
            <MudLink Href="/">Return to overview</MudLink> and connect to FreeAgent.
        </MudAlert>
    }
    else
    {
        <MudPaper Class="workbench-panel" Elevation="0">
            <MudStack Spacing="3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.List"
                           Disabled="_loading"
                           OnClick="FetchAsync">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Loading…</span>
                    }
                    else
                    {
                        <span>Load business categories</span>
                    }
                </MudButton>

                @if (_error is not null)
                {
                    <MudAlert Severity="Severity.Error" ShowCloseIcon="true"
                              CloseIconClicked="@(() => _error = null)">@_error</MudAlert>

                    <ApiErrorDiagnostics RawPayload="@_rawApiResponse" />
                }

                @if (_categories is null && !_loading)
                {
                    <MudText Typo="Typo.body2" Class="hero-copy">Press the button above to load business categories from FreeAgent.</MudText>
                }
                else if (_categories is not null && _categories.Count == 0 && !_loading)
                {
                    <MudText Typo="Typo.body2" Class="hero-copy">No business categories returned.</MudText>
                }

                @if (_categories is not null && _categories.Count > 0)
                {
                    <MudText Typo="Typo.subtitle1">@_categories.Count categories returned</MudText>
                    <MudGrid Spacing="2">
                        @foreach (var category in _categories)
                        {
                            <MudItem xs="12" sm="6" md="4">
                                <MudPaper Class="probe-card" Elevation="0">
                                    <MudText Typo="Typo.body2">@category</MudText>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                }
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    private bool _loading;
    private string? _error;
    private string? _rawApiResponse;
    private List<string>? _categories;

    private async Task FetchAsync()
    {
        var token = TokenStore.GetToken();
        if (token is null)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        _loading = true;
        _error = null;
        _rawApiResponse = null;
        _categories = null;

        try
        {
            using var client = OAuthService.CreateFreeAgentClient(token, TokenStore.ConnectedEnvironment);
            var categories = await client.Company.GetBusinessCategoriesAsync();
            _categories = categories.OrderBy(static x => x).ToList();
        }
        catch (FreeAgentApiException ex)
        {
            _error = $"API error: {ex.Message}";
            _rawApiResponse = await ApiDiagnostics.FetchRawEndpointPayloadAsync(
                token.AccessToken,
                TokenStore.ConnectedEnvironment,
                "company/business_categories");
        }
        catch (Exception ex)
        {
            _error = $"Unexpected error: {ex.Message}";
            _rawApiResponse = await ApiDiagnostics.FetchRawEndpointPayloadAsync(
                token.AccessToken,
                TokenStore.ConnectedEnvironment,
                "company/business_categories");
        }
        finally
        {
            _loading = false;
            _categories ??= new List<string>();
        }
    }
}
