@page "/contacts"
@inject TokenStore TokenStore
@inject OAuthService OAuthService
@inject ApiDiagnosticsService ApiDiagnostics
@inject NavigationManager NavigationManager

<PageTitle>Contacts — FreeAgent SDK Sample</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="sample-page">
    <EndpointProbeHeader SectionKicker="Contacts endpoint"
                         Title="Contacts auto-pagination"
                         CallUnderTest="ContactService.GetContactsPageAsync(...) + ContactService.GetAllContactsAsync(...)"
                         Description="Compares single-page access and full auto-pagination over the same contact dataset."
                         EndpointPath="/v2/contacts?page={page}&per_page={perPage}&view={view}" />

    @if (!TokenStore.IsConnected)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
            This probe needs an OAuth session first.
            <MudLink Href="/">Return to overview</MudLink> and connect to FreeAgent.
        </MudAlert>
    }
    else
    {
        <MudStack Spacing="3">
            @if (_error is not null)
            {
                <MudAlert Severity="Severity.Error" ShowCloseIcon="true"
                          CloseIconClicked="@(() => _error = null)">@_error</MudAlert>

                <ApiErrorDiagnostics RawPayload="@_rawApiResponse" />
            }

            <MudGrid Spacing="3">
                <MudItem xs="12" md="6">
                    <MudPaper Class="workbench-panel" Elevation="0">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.h6">Single page</MudText>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Filter1"
                                       Disabled="_loading"
                                       OnClick="LoadSinglePageAsync">
                                Load page 1
                            </MudButton>

                            @if (_singlePage is null && !_loading)
                            {
                                <MudText Typo="Typo.body2" Class="hero-copy">Press the button above to load page 1 of contacts.</MudText>
                            }
                            else if (_singlePage is not null && _singlePage.Count == 0 && !_loading)
                            {
                                <MudText Typo="Typo.body2" Class="hero-copy">No contacts found on page 1.</MudText>
                            }

                            @if (_singlePage is not null && _singlePage.Count > 0)
                            {
                                <MudText Typo="Typo.caption">@_singlePage.Count contacts loaded from page 1.</MudText>
                                @foreach (var contact in _singlePage)
                                {
                                    <MudPaper Class="probe-card" Elevation="0">
                                        <MudText Typo="Typo.body2">@contact.DisplayName</MudText>
                                    </MudPaper>
                                }
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudPaper Class="workbench-panel" Elevation="0">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.h6">Auto-pagination</MudText>
                            <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                                       StartIcon="@Icons.Material.Filled.AllInclusive"
                                       Disabled="_loading"
                                       OnClick="LoadAllAsync">
                                Load all contacts
                            </MudButton>

                            @if (_allContacts is null && !_loading)
                            {
                                <MudText Typo="Typo.body2" Class="hero-copy">Press the button above to load all contacts across all pages.</MudText>
                            }
                            else if (_allContacts is not null && _allContacts.Count == 0 && !_loading)
                            {
                                <MudText Typo="Typo.body2" Class="hero-copy">No contacts found across any page.</MudText>
                            }

                            @if (_allContacts is not null && _allContacts.Count > 0)
                            {
                                <MudText Typo="Typo.caption">@_allContacts.Count contacts loaded from all pages.</MudText>
                                @foreach (var contact in _allContacts)
                                {
                                    <MudPaper Class="probe-card" Elevation="0">
                                        <MudText Typo="Typo.body2">@contact.DisplayName</MudText>
                                    </MudPaper>
                                }
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudStack>
    }
</MudContainer>

@code {
    private bool _loading;
    private string? _error;
    private string? _rawApiResponse;
    private List<ContactSummary>? _singlePage;
    private List<ContactSummary>? _allContacts;

    private async Task LoadSinglePageAsync()
    {
        _singlePage = null;
        await WithClientAsync(async client =>
        {
            _singlePage = (await client.Contacts.GetContactsPageAsync(page: 1, perPage: 25, view: "all")).Items.ToList();
        }, "contacts?page=1&per_page=25&view=all");
        _singlePage ??= new List<ContactSummary>();
    }

    private async Task LoadAllAsync()
    {
        _allContacts = null;
        await WithClientAsync(async client =>
        {
            _allContacts = new List<ContactSummary>();
            await foreach (var contact in client.Contacts.GetAllContactsAsync(perPage: 25, view: "all"))
            {
                _allContacts.Add(contact);
            }
        }, "contacts?per_page=25&view=all");
        _allContacts ??= new List<ContactSummary>();
    }

    private async Task WithClientAsync(Func<FreeAgentClient, Task> action, string diagnosticsEndpoint)
    {
        var token = TokenStore.GetToken();
        if (token is null)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        _loading = true;
        _error = null;
        _rawApiResponse = null;

        try
        {
            using var client = OAuthService.CreateFreeAgentClient(token, TokenStore.ConnectedEnvironment);
            await action(client);
        }
        catch (FreeAgentApiException ex)
        {
            _error = $"API error: {ex.Message}";
            _rawApiResponse = await ApiDiagnostics.FetchRawEndpointPayloadAsync(
                token.AccessToken,
                TokenStore.ConnectedEnvironment,
                diagnosticsEndpoint);
        }
        catch (Exception ex)
        {
            _error = $"Unexpected error: {ex.Message}";
            _rawApiResponse = await ApiDiagnostics.FetchRawEndpointPayloadAsync(
                token.AccessToken,
                TokenStore.ConnectedEnvironment,
                diagnosticsEndpoint);
        }
        finally
        {
            _loading = false;
        }
    }
}
