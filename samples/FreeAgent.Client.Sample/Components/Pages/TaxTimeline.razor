@page "/company/tax-timeline"
@inject TokenStore TokenStore
@inject OAuthService OAuthService
@inject ApiDiagnosticsService ApiDiagnostics
@inject NavigationManager NavigationManager

<PageTitle>Tax Timeline — FreeAgent SDK Sample</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="sample-page">
    <EndpointProbeHeader SectionKicker="Company endpoint"
                         Title="Upcoming tax events"
                         CallUnderTest="CompanyService.GetTaxTimelineAsync()"
                         Description="Requires FreeAgent access level Tax, Accounting and Users."
                         EndpointPath="/v2/company/tax_timeline" />

    @if (!TokenStore.IsConnected)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
            This probe needs an OAuth session first.
            <MudLink Href="/">Return to overview</MudLink> and connect to FreeAgent.
        </MudAlert>
    }
    else
    {
        <MudPaper Class="workbench-panel" Elevation="0">
            <MudStack Spacing="3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Event"
                           Disabled="_loading"
                           OnClick="FetchAsync">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Loading…</span>
                    }
                    else
                    {
                        <span>Load tax timeline</span>
                    }
                </MudButton>

                @if (_error is not null)
                {
                    <MudAlert Severity="Severity.Error" ShowCloseIcon="true"
                              CloseIconClicked="@(() => _error = null)">@_error</MudAlert>

                    <ApiErrorDiagnostics RawPayload="@_rawApiResponse" />
                }

                @if (_items is null && !_loading)
                {
                    <MudText Typo="Typo.body2" Class="hero-copy">Press the button above to load the tax timeline from FreeAgent.</MudText>
                }
                else if (_items is not null && _items.Count == 0 && !_loading)
                {
                    <MudText Typo="Typo.body2" Class="hero-copy">No tax timeline events returned.</MudText>
                }

                @if (_items is not null && _items.Count > 0)
                {
                    <MudTimeline>
                        @foreach (var item in _items)
                        {
                            <MudTimelineItem Color="Color.Primary">
                                <ChildContent>
                                    <MudPaper Class="probe-card" Elevation="0">
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.subtitle2">@item.Description</MudText>
                                            <MudText Typo="Typo.body2">@item.Nature</MudText>
                                            <MudText Typo="Typo.caption">Date: @item.DatedOn.ToString("yyyy-MM-dd")</MudText>
                                            @if (item.AmountDue.HasValue)
                                            {
                                                <MudText Typo="Typo.caption">Amount due: @item.AmountDue.Value</MudText>
                                            }
                                        </MudStack>
                                    </MudPaper>
                                </ChildContent>
                            </MudTimelineItem>
                        }
                    </MudTimeline>
                }
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    private bool _loading;
    private string? _error;
    private string? _rawApiResponse;
    private List<TaxTimelineItem>? _items;

    private async Task FetchAsync()
    {
        var token = TokenStore.GetToken();
        if (token is null)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        _loading = true;
        _error = null;
        _rawApiResponse = null;
        _items = null;

        try
        {
            using var client = OAuthService.CreateFreeAgentClient(token, TokenStore.ConnectedEnvironment);
            var items = await client.Company.GetTaxTimelineAsync();
            _items = items.OrderBy(static i => i.DatedOn).ToList();
        }
        catch (FreeAgentApiException ex)
        {
            _error = $"API error: {ex.Message}";
            _rawApiResponse = await ApiDiagnostics.FetchRawEndpointPayloadAsync(
                token.AccessToken,
                TokenStore.ConnectedEnvironment,
                "company/tax_timeline");
        }
        catch (Exception ex)
        {
            _error = $"Unexpected error: {ex.Message}";
            _rawApiResponse = await ApiDiagnostics.FetchRawEndpointPayloadAsync(
                token.AccessToken,
                TokenStore.ConnectedEnvironment,
                "company/tax_timeline");
        }
        finally
        {
            _loading = false;
            _items ??= new List<TaxTimelineItem>();
        }
    }
}
