@page "/company"
@using System.Collections
@using System.Globalization
@using System.Reflection
@using System.Text.Json
@using System.Text.Json.Serialization
@inject TokenStore TokenStore
@inject OAuthService OAuthService
@inject ApiDiagnosticsService ApiDiagnostics
@inject NavigationManager NavigationManager

<PageTitle>Company — FreeAgent SDK Sample</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="sample-page">
    <EndpointProbeHeader SectionKicker="Implemented endpoint"
                         Title="Company overview"
                         CallUnderTest="CompanyService.GetCompanyAsync()"
                         Description="Shows general company information returned by the Company endpoint."
                         EndpointPath="/v2/company" />

    @if (!TokenStore.IsConnected)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
            This page needs an OAuth session first.
            <MudLink Href="/">Return to overview</MudLink> and connect to FreeAgent.
        </MudAlert>
    }
    else
    {
        <MudPaper Class="workbench-panel" Elevation="0">
            <MudStack Spacing="3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.CloudDownload"
                           Disabled="_loading"
                           OnClick="FetchCompanyAsync">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Running…</span>
                    }
                    else
                    {
                        <span>Fetch company</span>
                    }
                </MudButton>

                @if (_error is not null)
                {
                    <MudAlert Severity="Severity.Error" ShowCloseIcon="true"
                              CloseIconClicked="@(() => _error = null)">
                        @_error
                    </MudAlert>

                    <ApiErrorDiagnostics RawPayload="@_wireCompanyApiResponse" />
                }

                @if (_company is null && _error is null && !_loading)
                {
                    <MudText Typo="Typo.body2" Class="hero-copy">Press the button above to load company details from FreeAgent.</MudText>
                }

                @if (_company is not null)
                {
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                        <MudText Typo="Typo.h5">Result summary</MudText>
                        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">@_company.Currency</MudChip>
                        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Secondary">@_company.Type</MudChip>
                        <MudChip T="string" Variant="Variant.Filled" Color="Color.Success">Matches: @ExactMatchCount</MudChip>

                        @if (MismatchCount > 0)
                        {
                            <MudChip T="string" Variant="Variant.Filled" Color="Color.Error">Mismatches: @MismatchCount</MudChip>
                        }

                        @if (MissingInModelCount > 0)
                        {
                            <MudChip T="string" Variant="Variant.Filled" Color="Color.Error">Missing in model: @MissingInModelCount</MudChip>
                        }

                        @if (ModelOnlyCount > 0)
                        {
                            <MudChip T="string" Variant="Variant.Filled" Color="Color.Warning">Model-only values: @ModelOnlyCount</MudChip>
                        }
                    </MudStack>

                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <MudPaper Class="probe-card" Elevation="0">
                                <MudText Typo="Typo.caption">Name</MudText>
                                <MudText Typo="Typo.subtitle1">@_company.Name</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudPaper Class="probe-card" Elevation="0">
                                <MudText Typo="Typo.caption">Subdomain</MudText>
                                <MudText Typo="Typo.subtitle1">@_company.Subdomain</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudPaper Class="probe-card" Elevation="0">
                                <MudText Typo="Typo.caption">Registration No.</MudText>
                                <MudText Typo="Typo.subtitle1">@ValueOrFallback(_company.CompanyRegistrationNumber)</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudPaper Class="probe-card" Elevation="0">
                                <MudText Typo="Typo.caption">Sales Tax Status</MudText>
                                <MudText Typo="Typo.subtitle1">@ValueOrFallback(_company.SalesTaxRegistrationStatus?.ToString())</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudPaper Class="probe-card" Elevation="0">
                                <MudText Typo="Typo.caption">Mileage Units</MudText>
                                <MudText Typo="Typo.subtitle1">@ValueOrFallback(_company.MileageUnits?.ToString())</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudPaper Class="probe-card" Elevation="0">
                                <MudText Typo="Typo.caption">Resource URL</MudText>
                                <MudText Typo="Typo.body2">@_company.Url</MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    <MudDivider />

                    <MudText Typo="Typo.h6">Wire-to-model mapping inspection</MudText>

                    @if (_mappingRows.Count == 0)
                    {
                        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                            Mapping diagnostics are unavailable because no raw wire payload could be parsed.
                        </MudAlert>
                    }
                    else
                    {
                        <MudTable Items="@_mappingRows" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                            <HeaderContent>
                                <MudTh>Status</MudTh>
                                <MudTh>JSON field</MudTh>
                                <MudTh>Raw value</MudTh>
                                <MudTh>Raw kind</MudTh>
                                <MudTh>Model property</MudTh>
                                <MudTh>Model type</MudTh>
                                <MudTh>Model value</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Status">
                                    <MudChip T="string" Variant="Variant.Filled" Size="Size.Small" Color="@GetStatusColor(context.Status)">
                                        @GetStatusLabel(context.Status)
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="JSON field"><code>@context.JsonFieldName</code></MudTd>
                                <MudTd DataLabel="Raw value">@context.RawValue</MudTd>
                                <MudTd DataLabel="Raw kind"><code>@context.RawValueKind</code></MudTd>
                                <MudTd DataLabel="Model property"><code>@context.PropertyName</code></MudTd>
                                <MudTd DataLabel="Model type"><code>@context.ModelTypeName</code></MudTd>
                                <MudTd DataLabel="Model value">@context.ModelValue</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }

                    <MudDivider />

                    <MudText Typo="Typo.h6">All Company model fields</MudText>
                    <MudTable Items="@_companyFields" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                        <HeaderContent>
                            <MudTh>Property</MudTh>
                            <MudTh>JSON field</MudTh>
                            <MudTh>Type</MudTh>
                            <MudTh>Value</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Property"><code>@context.PropertyName</code></MudTd>
                            <MudTd DataLabel="JSON field"><code>@context.JsonFieldName</code></MudTd>
                            <MudTd DataLabel="Type"><code>@context.TypeName</code></MudTd>
                            <MudTd DataLabel="Value">@context.Value</MudTd>
                        </RowTemplate>
                    </MudTable>

                    <MudDivider />

                    <MudExpansionPanels MultiExpansion="true">
                        <MudExpansionPanel Text="Raw JSON (wire payload snapshot)">
                            <ApiErrorDiagnostics RawPayload="@_wireCompanyApiResponse" MaxLines="120" />
                        </MudExpansionPanel>

                        <MudExpansionPanel Text="Raw JSON (SDK model snapshot)">
                            <MudPaper Class="probe-card raw-json-panel" Elevation="0">
                                <pre>@_companyJson</pre>
                            </MudPaper>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                }
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    private bool _loading;
    private string? _error;
    private FreeAgent.Client.Models.Company.Company? _company;
    private string _companyJson = string.Empty;
    private string _wireCompanyApiResponse = string.Empty;
    private List<CompanyFieldRow> _companyFields = new();
    private List<CompanyMappingRow> _mappingRows = new();

    private int ExactMatchCount => _mappingRows.Count(static row => row.Status == MappingCheckStatus.Match);

    private int MismatchCount => _mappingRows.Count(static row => row.Status == MappingCheckStatus.Mismatch);

    private int MissingInModelCount => _mappingRows.Count(static row => row.Status == MappingCheckStatus.MissingInModel);

    private int ModelOnlyCount => _mappingRows.Count(static row => row.Status == MappingCheckStatus.ModelOnly);

    private async Task FetchCompanyAsync()
    {
        var token = TokenStore.GetToken();
        if (token is null)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        _loading = true;
        _error = null;
        _company = null;
        _companyJson = string.Empty;
        _wireCompanyApiResponse = string.Empty;
        _companyFields = [];
        _mappingRows = [];

        try
        {
            using var client = OAuthService.CreateFreeAgentClient(token, TokenStore.ConnectedEnvironment);
            _company = await client.Company.GetCompanyAsync();

            _wireCompanyApiResponse = await ApiDiagnostics.FetchRawEndpointPayloadAsync(
                token.AccessToken,
                TokenStore.ConnectedEnvironment,
                "company");

            _companyJson = JsonSerializer.Serialize(_company, PrettyJsonOptions);
            _companyFields = BuildCompanyFieldRows(_company);
            _mappingRows = BuildMappingRows(_company, _wireCompanyApiResponse);
        }
        catch (JsonException ex)
        {
            _error = $"Model deserialisation error: {ex.Message}";
            _wireCompanyApiResponse = await ApiDiagnostics.FetchRawEndpointPayloadAsync(
                token.AccessToken,
                TokenStore.ConnectedEnvironment,
                "company");
        }
        catch (FreeAgentApiException ex)
        {
            _error = $"API error: {ex.Message}";
            _wireCompanyApiResponse = await ApiDiagnostics.FetchRawEndpointPayloadAsync(
                token.AccessToken,
                TokenStore.ConnectedEnvironment,
                "company");
        }
        catch (Exception ex)
        {
            _error = $"Unexpected error: {ex.Message}";
            _wireCompanyApiResponse = await ApiDiagnostics.FetchRawEndpointPayloadAsync(
                token.AccessToken,
                TokenStore.ConnectedEnvironment,
                "company");
        }
        finally
        {
            _loading = false;
        }
    }

    private static string ValueOrFallback(string? value) => string.IsNullOrWhiteSpace(value) ? "Not returned" : value;

    private static readonly JsonSerializerOptions PrettyJsonOptions = new()
    {
        WriteIndented = true
    };

    private static List<CompanyFieldRow> BuildCompanyFieldRows(FreeAgent.Client.Models.Company.Company company)
    {
        var rows = new List<CompanyFieldRow>();

        foreach (var property in typeof(FreeAgent.Client.Models.Company.Company).GetProperties(BindingFlags.Instance | BindingFlags.Public))
        {
            var rawValue = property.GetValue(company);
            var jsonName = property.GetCustomAttribute<JsonPropertyNameAttribute>()?.Name ?? property.Name;
            var stringValue = rawValue switch
            {
                null => "Not returned",
                string text when string.IsNullOrWhiteSpace(text) => "Not returned",
                string text => text,
                DateOnly date => date.ToString("yyyy-MM-dd"),
                IEnumerable<string> stringCollection => string.Join(", ", stringCollection),
                _ => JsonSerializer.Serialize(rawValue)
            };

            rows.Add(new CompanyFieldRow(
                property.Name,
                jsonName,
                FormatTypeName(property.PropertyType),
                stringValue));
        }

        return rows;
    }

    private static List<CompanyMappingRow> BuildMappingRows(
        FreeAgent.Client.Models.Company.Company company,
        string rawPayload)
    {
        if (string.IsNullOrWhiteSpace(rawPayload))
        {
            return [];
        }

        JsonElement companyElement;
        try
        {
            using var document = JsonDocument.Parse(rawPayload);
            companyElement = ExtractCompanyNode(document.RootElement);
        }
        catch (JsonException)
        {
            return [];
        }

        var rows = new List<CompanyMappingRow>();
        foreach (var property in typeof(FreeAgent.Client.Models.Company.Company).GetProperties(BindingFlags.Instance | BindingFlags.Public))
        {
            var jsonName = property.GetCustomAttribute<JsonPropertyNameAttribute>()?.Name ?? property.Name;
            var modelRawValue = property.GetValue(company);
            JsonElement rawElement = default;
            var hasRawValue = companyElement.ValueKind == JsonValueKind.Object && companyElement.TryGetProperty(jsonName, out rawElement);

            var status = DetermineMappingStatus(
                hasRawValue,
                hasRawValue ? rawElement : default,
                modelRawValue,
                property.PropertyType);

            rows.Add(new CompanyMappingRow(
                property.Name,
                jsonName,
                FormatTypeName(property.PropertyType),
                FormatModelValue(modelRawValue),
                hasRawValue ? FormatJsonValue(rawElement) : "Not returned",
                hasRawValue ? rawElement.ValueKind.ToString() : "Not returned",
                status));
        }

        return rows;
    }

    private static JsonElement ExtractCompanyNode(JsonElement rootElement)
    {
        if (rootElement.ValueKind == JsonValueKind.Object &&
            rootElement.TryGetProperty("company", out var companyNode) &&
            companyNode.ValueKind == JsonValueKind.Object)
        {
            return companyNode.Clone();
        }

        return rootElement.Clone();
    }

    private static MappingCheckStatus DetermineMappingStatus(
        bool hasRawValue,
        JsonElement rawValue,
        object? modelValue,
        Type propertyType)
    {
        var hasModelValue = HasMeaningfulValue(modelValue);

        if (!hasRawValue)
        {
            return hasModelValue ? MappingCheckStatus.ModelOnly : MappingCheckStatus.NotReturned;
        }

        if (!hasModelValue)
        {
            return MappingCheckStatus.MissingInModel;
        }

        return ValuesEquivalent(rawValue, modelValue!, propertyType)
            ? MappingCheckStatus.Match
            : MappingCheckStatus.Mismatch;
    }

    private static bool HasMeaningfulValue(object? value)
    {
        switch (value)
        {
            case null:
                return false;
            case string stringValue:
                return !string.IsNullOrWhiteSpace(stringValue);
            case IEnumerable enumerable when value is not string:
            {
                var enumerator = enumerable.GetEnumerator();
                try
                {
                    return enumerator.MoveNext();
                }
                finally
                {
                    (enumerator as IDisposable)?.Dispose();
                }
            }
            default:
                return true;
        }
    }

    private static bool ValuesEquivalent(JsonElement rawValue, object modelValue, Type propertyType)
    {
        var actualType = Nullable.GetUnderlyingType(propertyType) ?? propertyType;

        if (actualType.IsEnum)
        {
            return EnumValueMatchesRaw(rawValue, actualType, modelValue);
        }

        if (actualType == typeof(DateOnly) && modelValue is DateOnly dateOnlyValue)
        {
            return rawValue.ValueKind == JsonValueKind.String
                && DateOnly.TryParse(rawValue.GetString(), out var parsedDate)
                && parsedDate == dateOnlyValue;
        }

        if (actualType == typeof(DateTimeOffset) && modelValue is DateTimeOffset dateTimeOffsetValue)
        {
            return rawValue.ValueKind == JsonValueKind.String
                && DateTimeOffset.TryParse(rawValue.GetString(), out var parsedDateTimeOffset)
                && parsedDateTimeOffset == dateTimeOffsetValue;
        }

        if (actualType == typeof(string) && modelValue is string stringValue)
        {
            return rawValue.ValueKind == JsonValueKind.String
                && string.Equals(rawValue.GetString(), stringValue, StringComparison.Ordinal);
        }

        if (actualType == typeof(bool) && modelValue is bool boolValue)
        {
            return (rawValue.ValueKind == JsonValueKind.True || rawValue.ValueKind == JsonValueKind.False)
                && rawValue.GetBoolean() == boolValue;
        }

        if (TryReadDecimal(rawValue, out var rawDecimal) && TryReadDecimal(modelValue, out var modelDecimal))
        {
            return rawDecimal == modelDecimal;
        }

        if (rawValue.ValueKind is JsonValueKind.Array or JsonValueKind.Object)
        {
            try
            {
                using var modelDocument = JsonDocument.Parse(JsonSerializer.Serialize(modelValue));
                return JsonElement.DeepEquals(rawValue, modelDocument.RootElement);
            }
            catch (JsonException)
            {
                return false;
            }
        }

        return string.Equals(
            FormatJsonValue(rawValue),
            FormatModelValue(modelValue),
            StringComparison.Ordinal);
    }

    private static bool EnumValueMatchesRaw(JsonElement rawValue, Type enumType, object modelValue)
    {
        if (rawValue.ValueKind != JsonValueKind.String)
        {
            return false;
        }

        var rawString = rawValue.GetString();
        if (string.IsNullOrWhiteSpace(rawString))
        {
            return false;
        }

        var memberName = modelValue.ToString();
        if (string.IsNullOrWhiteSpace(memberName))
        {
            return false;
        }

        var member = enumType.GetMember(memberName).FirstOrDefault();
        var wireName = member?.GetCustomAttribute<JsonStringEnumMemberNameAttribute>()?.Name;

        return !string.IsNullOrWhiteSpace(wireName)
            ? string.Equals(rawString, wireName, StringComparison.Ordinal)
            : NormalizeToken(rawString) == NormalizeToken(memberName);
    }

    private static string NormalizeToken(string value) =>
        value.Replace("-", string.Empty, StringComparison.Ordinal)
            .Replace("_", string.Empty, StringComparison.Ordinal)
            .Replace(" ", string.Empty, StringComparison.Ordinal)
            .Trim()
            .ToLowerInvariant();

    private static bool TryReadDecimal(JsonElement rawValue, out decimal value)
    {
        if (rawValue.ValueKind == JsonValueKind.Number)
        {
            return rawValue.TryGetDecimal(out value);
        }

        if (rawValue.ValueKind == JsonValueKind.String)
        {
            return decimal.TryParse(rawValue.GetString(), NumberStyles.Any, CultureInfo.InvariantCulture, out value);
        }

        value = default;
        return false;
    }

    private static bool TryReadDecimal(object rawValue, out decimal value)
    {
        switch (rawValue)
        {
            case decimal decimalValue:
                value = decimalValue;
                return true;
            case int intValue:
                value = intValue;
                return true;
            case long longValue:
                value = longValue;
                return true;
            case short shortValue:
                value = shortValue;
                return true;
            case double doubleValue:
                value = Convert.ToDecimal(doubleValue, CultureInfo.InvariantCulture);
                return true;
            case float floatValue:
                value = Convert.ToDecimal(floatValue, CultureInfo.InvariantCulture);
                return true;
            case string stringValue:
                return decimal.TryParse(stringValue, NumberStyles.Any, CultureInfo.InvariantCulture, out value);
            default:
                value = default;
                return false;
        }
    }

    private static string FormatJsonValue(JsonElement value)
    {
        return value.ValueKind switch
        {
            JsonValueKind.String => value.GetString() ?? string.Empty,
            JsonValueKind.Number => value.GetRawText(),
            JsonValueKind.True => bool.TrueString,
            JsonValueKind.False => bool.FalseString,
            JsonValueKind.Null => "Not returned",
            JsonValueKind.Array or JsonValueKind.Object => JsonSerializer.Serialize(value, PrettyJsonOptions),
            _ => value.GetRawText()
        };
    }

    private static string FormatModelValue(object? value)
    {
        return value switch
        {
            null => "Not returned",
            string stringValue when string.IsNullOrWhiteSpace(stringValue) => "Not returned",
            string stringValue => stringValue,
            DateOnly dateOnlyValue => dateOnlyValue.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture),
            DateTimeOffset dateTimeOffsetValue => dateTimeOffsetValue.ToString("O", CultureInfo.InvariantCulture),
            bool boolValue => boolValue.ToString(CultureInfo.InvariantCulture),
            int intValue => intValue.ToString(CultureInfo.InvariantCulture),
            long longValue => longValue.ToString(CultureInfo.InvariantCulture),
            decimal decimalValue => decimalValue.ToString(CultureInfo.InvariantCulture),
            Enum enumValue => enumValue.ToString(),
            IEnumerable _ when value is not string => JsonSerializer.Serialize(value, PrettyJsonOptions),
            _ => JsonSerializer.Serialize(value, PrettyJsonOptions)
        };
    }

    private static string GetStatusLabel(MappingCheckStatus status)
    {
        return status switch
        {
            MappingCheckStatus.Match => "Match",
            MappingCheckStatus.Mismatch => "Mismatch",
            MappingCheckStatus.MissingInModel => "Missing in model",
            MappingCheckStatus.ModelOnly => "Model-only",
            _ => "Not returned"
        };
    }

    private static Color GetStatusColor(MappingCheckStatus status)
    {
        return status switch
        {
            MappingCheckStatus.Match => Color.Success,
            MappingCheckStatus.Mismatch => Color.Error,
            MappingCheckStatus.MissingInModel => Color.Error,
            MappingCheckStatus.ModelOnly => Color.Warning,
            _ => Color.Default
        };
    }

    private static string FormatTypeName(Type type)
    {
        if (Nullable.GetUnderlyingType(type) is Type nullableType)
        {
            return $"{FormatTypeName(nullableType)}?";
        }

        if (type.IsGenericType)
        {
            var genericTypeName = type.Name[..type.Name.IndexOf('`')];
            var genericArguments = string.Join(", ", type.GetGenericArguments().Select(FormatTypeName));
            return $"{genericTypeName}<{genericArguments}>";
        }

        return type.Name;
    }

    private sealed record CompanyFieldRow(string PropertyName, string JsonFieldName, string TypeName, string Value);

    private sealed record CompanyMappingRow(
        string PropertyName,
        string JsonFieldName,
        string ModelTypeName,
        string ModelValue,
        string RawValue,
        string RawValueKind,
        MappingCheckStatus Status);

    private enum MappingCheckStatus
    {
        Match,
        Mismatch,
        MissingInModel,
        ModelOnly,
        NotReturned
    }
}
